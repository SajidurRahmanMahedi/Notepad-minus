# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source files
*.py text diff=python
*.txt text
*.md text
*.yml text
*.yaml text
*.json text
*.toml text
*.cfg text
*.ini text

# Shell scripts
*.sh text eol=lf

# Windows-specific files should use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.iss text eol=crlf

# Binary files
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
